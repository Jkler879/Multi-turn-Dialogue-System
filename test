from src.core.conversation_data_postgresql.conversation_data import PGMemory
from src.core.high_frequency_query_cache.rate_limiter import RateLimiter, RateLimitExceeded
from src.core.high_frequency_query_cache.circuit_breaker import CircuitBreaker, CircuitBreakerOpen
from src.core.high_frequency_query_cache.redis_bloom import advanced_normalize
from src.core.memory_long.forgetting_task import ForgettingTask

# 工具集导入
from src.core.ReAct_Agent.tools.retriever import RetrieverTool, BGEReranker
from src.core.ReAct_Agent.tools.relation_verifier import create_relation_verifier_tool
from src.core.ReAct_Agent.tools.translate import create_translator_tool

# langsmith监控导入
import os
from pathlib import Path
from dotenv import load_dotenv

# 强制使用环境变量
env_path = Path(__file__).parent.parent / '.env'
load_dotenv(dotenv_path=env_path, override=True)

# Lang验证
api_key = os.getenv("LANGCHAIN_API_KEY")
if api_key:
    print(f"✅ LangSmith API Key 已加载: {api_key[:5]}...")
else:
    print("⚠️ 未找到 LangSmith API Key，请检查 .env 文件")

# 全局变量
background_tasks = set()
pg_memory: PGMemory = None      # [NEW] PG 存储模块，延迟初始化
long_term_memory: LongTermMemory = None
http_client: httpx.AsyncClient = None
forgetting_task: Optional['ForgettingTask'] = None   # 新增

# ========== 1. 初始化 Redis 客户端 ==========
redis_client = redis.Redis(**REDIS_CONFIG)
try:
    redis_client.ping()
    print("✅ Redis 连接成功")
except redis.ConnectionError:
    raise RuntimeError("❌ Redis 连接失败")


# ========== 2. 初始化嵌入模型 ==========
embeddings = OllamaEmbeddings(
    model=OLLAMA_CONFIG['embed_model'],
    base_url=OLLAMA_CONFIG['base_url']
)


# ========== 3. 获取 pymilvus Collection 实例 ==========
connections.connect(**MILVUS_CONFIG)
milvus_collection = Collection(MILVUS_COLLECTION)


# ========== 初始化重排器 ==========
reranker = BGEReranker(
    model_path=RERANKER_CONFIG['model_path'],
    device=RERANKER_CONFIG['device']
)

# ========== 4. 初始化 LLM ==========
llm = ChatOpenAI(
    model=API_CONFIG['model'],
    openai_api_key=API_CONFIG['api_key'],
    openai_api_base=API_CONFIG['base_url'],
    temperature=API_CONFIG['temperature'],
    streaming=False,
)

# ========== 5. 创建检索工具（移除 vectorstore）==========
retriever = RetrieverTool(
    embedding_model=embeddings,          # 嵌入模型
    milvus_collection=milvus_collection,  # 用于向量检索和 BM25 的 Milvus 集合
    reranker=reranker,
    vector_top_k=RETRIEVAL_CONFIG['vector_top_k'],
    bm25_top_k=RETRIEVAL_CONFIG['bm25_top_k'],
    rrf_final_top_k=RETRIEVAL_CONFIG['rrf_final_top_k'],
    absolute_low=RETRIEVAL_CONFIG.get('absolute_low', -5.0),  # 绝对下限阈值，低于此值返回空结果
    vector_search_params={"metric_type": "COSINE", "params": {"nprobe": 128}}
)
retriever_tool = retriever.as_tool()

# ========== 6. 创建验证工具 ==========
verifier_tool = create_relation_verifier_tool(
    neo4j_url=NEO4J_CONFIG['url'],
    neo4j_user=NEO4J_CONFIG['user'],
    neo4j_password=NEO4J_CONFIG['password'],
    default_min_confidence=0.5,
)

# ========== 7. 创建翻译工具 ==========
translator_tool = create_translator_tool(
    model_path=TRANSLATOR_CONFIG['model_path'],
    device=TRANSLATOR_CONFIG['device']
)

# 8.4 获取记忆工具并加入工具列表
tools = [retriever_tool, verifier_tool, translator_tool]

# ========== 9. 创建 Agent（传入 store）==========
agent_app = create_react_agent(
    llm=llm,
    tools=tools,
)

# ========== 10. 查询改写和高频查询缓存模块 ==========
rewriter = QueryRewriter(
    redis_client=redis_client,
    max_history_turns=REWRITER_CONFIG['max_history_turns'],
    ollama_base_url=OLLAMA_CONFIG['base_url'],
    ollama_model=OLLAMA_CONFIG['model'],
    rewrite_timeout=REWRITER_CONFIG['timeout'],
    max_retries=REWRITER_CONFIG['max_retries'],
    enable_warmup=True
)

cache = HighFreqCache(
    redis_client=redis_client,
    threshold=CACHE_CONFIG['threshold'],
    window_seconds=CACHE_CONFIG['window_seconds'],
    bloom_capacity=CACHE_CONFIG['bloom_capacity'],
    bloom_error_rate=CACHE_CONFIG['bloom_error_rate']
)

# ========== 11. 初始化短期记忆管理器 ==========
memory = ShortTermMemory(
    redis_client=redis_client,
    max_history_turns=MEMORY_CONFIG['max_history_turns'],
    expire_seconds=MEMORY_CONFIG['expire_seconds']
)

# ========== 12. 初始化限流器 ==========
rate_limiter = RateLimiter(
    redis_client=redis_client,
    global_rate=5,  # 全局：每秒 5 次
    user_rate=20,    # 用户：每分钟 20 次
    query_rate=3,    # 热点 query：每秒 3 次
)

# ========== 13. 初始化熔断器 ==========
circuit_breaker = CircuitBreaker(
    redis_client=redis_client,
    name="agent",
    failure_threshold=0.5,  # 失败率 50% 触发
    min_samples=5,  # 最少 5 个样本才触发
    window_seconds=60,  # 滑动窗口 60 秒
    open_duration=30,  # 断开持续 30 秒
    half_open_max=2,  # 半开最多放行 2 个探测
)


# ========== 13. 异步请求处理函数 ==========
async def handle_request_async(user_input: str, session_id: str, user_id: str = "default_user") -> str:
    global pg_memory, long_term_memory, http_client, forgetting_task
    logger.info(f"🚀 开始处理请求: user_input='{user_input}', session_id='{session_id}', user_id='{user_id}'")

    # PG 连接池延迟初始化（只在第一次请求时执行一次）
    global pg_memory
    if pg_memory is None:
        pg_memory = PGMemory(
            dsn=PG_CONFIG["dsn"],
            min_size=PG_CONFIG.get("pool_min_size", 2),
            max_size=PG_CONFIG.get("pool_max_size", 10),
        )
        await pg_memory.initialize()

        # 创建全局 HTTP 客户端（复用）
        if http_client is None:
            http_client = httpx.AsyncClient(timeout=120.0)

        # 初始化遗忘任务（复用 pg_memory 的连接池）
        if forgetting_task is None:
            forgetting_task = ForgettingTask(
                db_pool=pg_memory.pool,
                score_threshold=FORGETTING_CONFIG['score_threshold'],
                capacity_per_user=FORGETTING_CONFIG['capacity_per_user'],
            )

        # 初始化长期记忆，复用 pg_memory 的连接池
        long_term_memory = LongTermMemory(
            db_pool=pg_memory.pool,  # 需要 PGMemory 暴露 self.pool 属性
            http_client=http_client,
            ollama_base_url=OLLAMA_CONFIG['base_url'],
            embed_model=OLLAMA_CONFIG['embed_model'],
            extract_model=OLLAMA_CONFIG['extract_model'],
            merge_model=OLLAMA_CONFIG['merge_model'],
            top_k=LTM_CONFIG['top_k'],
            max_candidates=LTM_CONFIG['max_candidates'],
            similar_existing_limit=LTM_CONFIG['similar_existing_limit'],
            forgetting_task=forgetting_task,  # 传入
        )

    # ── [NEW] A. 限流检查（第一道闸，所有业务逻辑之前）─────────
    norm_for_rl = advanced_normalize(user_input)
    rate_limiter.check(user_id=user_id, norm_query=norm_for_rl)
    # 触发时抛出 RateLimitExceeded → api.py 捕获 → HTTP 429 + Retry-After

    # 1. 查询改写
    rewritten_dict = rewriter.rewrite(user_input, session_id)
    en_query = rewritten_dict["en_query"]
    zh_query = rewritten_dict["zh_query"]
    logger.info(f"✍️ 查询改写结果: en='{en_query}', zh='{zh_query}'")

    # 2. 检查高频缓存
    cached = cache.get(en_query)
    if cached is not None:
        logger.info("🎯 缓存命中，直接返回缓存答案")
        memory.add_turn(session_id, user_input, cached)
        pg_task = asyncio.create_task(
            pg_memory.write_turn(
                session_id=session_id, user_id=user_id,
                user_input=user_input, assistant_output=cached,
                metadata={"cache_hit": True},
            )
        )
        background_tasks.add(pg_task)
        pg_task.add_done_callback(background_tasks.discard)
        return cached
    else:
        logger.info("❌ 缓存未命中")

    # ── [NEW] B. 互斥锁：防止高频 query 缓存过期时被同时击穿 ───
    lock_acquired = False
    if cache.is_high_freq(en_query):
        lock_acquired = cache.try_lock(en_query)
        if not lock_acquired:
            logger.info("🔒 未拿到互斥锁，等待缓存写入...")
            # 最多3 次等待
            for _ in range(3):
                await asyncio.sleep(0.3)
                cached = cache.get(en_query)
                if cached is not None:
                    logger.info("🎯 等待后缓存命中")
                    memory.add_turn(session_id, user_input, cached)
                    pg_task = asyncio.create_task(
                        pg_memory.write_turn(
                            session_id=session_id, user_id=user_id,
                            user_input=user_input, assistant_output=cached,
                            metadata={"cache_hit": True, "mutex_wait": True},
                        )
                    )
                    background_tasks.add(pg_task)
                    pg_task.add_done_callback(background_tasks.discard)
                    return cached
            # 3 次等待后仍无缓存：放行到 Agent（不持有锁）
            logger.warning("⚠️ 互斥锁等待超时，直接放行到 Agent")

    # 3. 加载短期记忆
    short_term_msgs = memory.get_messages(session_id)
    logger.info(f"📚 加载短期记忆: 共 {len(short_term_msgs)} 条消息")
    if short_term_msgs:
        mem_preview = "；".join([msg.content[:100] for msg in short_term_msgs])
        logger.info(f"📝 短期记忆内容: {mem_preview}")

    # 4. 预取长期记忆
    memories = await long_term_memory.retrieve_relevant(
        user_id=user_id,
        query=zh_query,
        memory_type=None,
    )
    logger.info(f"🧠 加载长期记忆: 共 {len(memories)} 条相关记忆")

    # 5. 构造初始消息
    initial_messages = short_term_msgs[:]
    if memories:
        mem_text = "；".join([m["content"] for m in memories])
        initial_messages.append(SystemMessage(content=f"用户长期记忆：{mem_text}"))
    initial_messages.append(HumanMessage(content=en_query))

    # ── [NEW] C. 熔断器包裹 Agent 调用 ─────────────────────────
    logger.info("🤖 开始调用 Agent...")
    final_answer = None
    try:
        circuit_breaker.before_call()  # OPEN 状态时抛出 CircuitBreakerOpen

        result = await agent_app.ainvoke({
            "messages": initial_messages,
            "step_count": 0,
            "max_steps": 5
        })
        final_answer = result.get("final_answer", "抱歉，我无法回答这个问题。")
        logger.info(f"✅ Agent 调用完成: {final_answer[:200]}...")

        circuit_breaker.on_success()  # 记录成功，半开探测成功时恢复闭合

    except CircuitBreakerOpen:
        # 熔断断开：返回降级响应，不写缓存，不写 PG，释放锁
        logger.warning("⚡ 熔断器断开，返回降级响应")
        if lock_acquired:
            cache.release_lock(en_query)
        return "系统暂时繁忙，请稍后再试。"

    except Exception as e:
        circuit_breaker.on_failure(e)  # 记录失败，可能触发断开
        if lock_acquired:
            cache.release_lock(en_query)
        raise

    # 7. 异步处理长期记忆
    task = asyncio.create_task(
        long_term_memory.process_and_store(
            user_id=user_id,
            user_input=user_input,
            assistant_output=final_answer,
        )
    )
    background_tasks.add(task)
    task.add_done_callback(background_tasks.discard)
    logger.debug("长期记忆异步处理任务已提交")

    # 8. 更新缓存和短期记忆
    cache.update(en_query, final_answer)
    if lock_acquired:
        cache.release_lock(en_query)  # [NEW] 写完缓存后释放锁
    memory.add_turn(session_id, user_input, final_answer)
    logger.info("💾 缓存和短期记忆已更新")

    # 9. PG 异步写入全量对话数据
    pg_task = asyncio.create_task(
        pg_memory.write_turn(
            session_id=session_id, user_id=user_id,
            user_input=user_input, assistant_output=final_answer,
            metadata={"cache_hit": False},
        )
    )
    background_tasks.add(pg_task)
    pg_task.add_done_callback(background_tasks.discard)

    return final_answer


# ========== 14. 同步包装器 ==========
def handle_request(user_input: str, session_id: str, user_id: str = "default_user") -> str:
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    try:
        result = loop.run_until_complete(
            handle_request_async(user_input, session_id, user_id)
        )
        if background_tasks:
            done, pending = loop.run_until_complete(
                asyncio.wait(background_tasks, timeout=10)
            )
            if pending:
                logger.warning(f"有 {len(pending)} 个后台任务未在10秒内完成")
        return result
    finally:
        # 关闭 HTTP 客户端和 PG 连接池
        if http_client is not None:
            loop.run_until_complete(http_client.aclose())
        if pg_memory is not None:
            loop.run_until_complete(pg_memory.close())
        loop.close()


# ========== 14. 测试运行 ==========
if __name__ == "__main__":
    test_query = "有什么好看的科幻电视剧推荐吗？"
    test_session = "test_001"
    test_user = "test_01"
    answer = handle_request(test_query, test_session, test_user)
    logger.info(f"最终答案: {answer}")
